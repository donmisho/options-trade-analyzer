# ============================================================
# Options Analyzer — Local Development Configuration
# ============================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# --- App ---
DEBUG=true

# --- Azure Key Vault ---
# Leave empty for local dev (uses env vars below instead)
# Set to your vault URL for production: https://your-vault.vault.azure.net
AZURE_KEYVAULT_URL=

# --- Secrets (local dev only — in production these live in Key Vault) ---
# Generate a random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SIGNING_KEY=change-me-to-a-random-64-char-hex-string


# --- Schwab OAuth ---
SCHWAB_APP_KEY=your-schwab-app-key
SCHWAB_APP_SECRET=your-schwab-app-secret
SCHWAB_CALLBACK_URL=https://127.0.0.1:8000/api/v1/auth/schwab/callback
DEFAULT_MARKET_DATA_PROVIDER=schwab